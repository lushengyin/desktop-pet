{
  "name": "desktop-pet",
  "version": "0.1.0",
  "description": "A macOS-first desktop pet app starring Lulu.",
  "type": "module",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on tcp:5173 dist-electron/main/main.js && electron .\"",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "build": "tsc --noEmit && tsc -p tsconfig.electron.json && vite build",
    "smoke": "pnpm run build && LULU_SMOKE_TEST=1 electron .",
    "package": "pnpm run build && electron-builder --mac --dir",
    "dist": "pnpm run build && electron-builder --mac"
  },
  "keywords": [
    "desktop-pet",
    "electron",
    "react",
    "lulu"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.lusheng.desktop-pet",
    "productName": "Lulu Desktop Pet",
    "files": [
      "dist/**",
      "dist-electron/**",
      "build/tray.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/tray.png",
        "to": "tray.png"
      }
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.lifestyle",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
